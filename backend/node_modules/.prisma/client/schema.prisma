generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./prisma/dev.db"
}

model ResumeSession {
  id            String   @id @default(uuid())
  parsedJson    String?
  optimizedJson String?
  latexSource   String?
  pdfPath       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
